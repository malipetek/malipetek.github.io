---
import BaseLayout from "../layouts/BaseLayout.astro";
import { featuredProducts } from "../data/projects";
import { services } from "../data/services";
import { featuredStoreProducts, formatLocalPrice, formatPrice } from "../data/store";
import { absoluteUrl } from "../data/site";

const buildLanes = [
  "AI workflows and agentic products",
  "Agentic commerce readiness, structured product data, and ACP planning",
  "Cloudflare Workers, D1, Pages, and GitHub-backed control planes",
  "Convex real-time TypeScript products",
  "Svelte/Astro publishing systems",
  "SwiftUI and iOS product prototypes",
  "Self-hosted infrastructure and developer tools",
  "E-commerce integrations and technical rescue",
];

const proofStats = [
  ["Current fit", "Fractional, contract, and scoped product engineering"],
  ["Availability", "10-25 hours/week, remote async, Istanbul / Europe timezone"],
  ["Best use", "Paid discovery -> prototype -> build"],
];
const homepageSchema = [
  {
    "@type": "ItemList",
    "@id": `${absoluteUrl("/")}#store-packages`,
    name: "Fixed-scope software implementation packages",
    itemListElement: featuredStoreProducts.map((product, index) => ({
      "@type": "ListItem",
      position: index + 1,
      name: product.title,
      url: absoluteUrl(`/store/${product.slug}`),
    })),
  },
  {
    "@type": "ItemList",
    "@id": `${absoluteUrl("/")}#featured-products`,
    name: "Featured products and productized systems",
    itemListElement: featuredProducts.map((product, index) => ({
      "@type": "ListItem",
      position: index + 1,
      name: product.title,
      url: absoluteUrl(`/products/${product.slug}`),
    })),
  },
  {
    "@type": "ItemList",
    "@id": `${absoluteUrl("/")}#services`,
    name: "Product engineering services",
    itemListElement: services.map((service, index) => ({
      "@type": "ListItem",
      position: index + 1,
      name: service.title,
      url: absoluteUrl(`/services/${service.slug}`),
    })),
  },
];
---

<BaseLayout
  title="Muhammet Ali Petek"
  description="Full-stack product engineer building AI-assisted products, Cloudflare/Convex platforms, Svelte/Astro apps, SwiftUI prototypes, and weird useful tools."
  wide={true}
  schema={homepageSchema}
>
  <section class="portfolio-hero full-bleed">
    <div class="container hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">Available for fractional and scoped product engineering</p>
        <h1>Muhammet Ali Petek</h1>
        <p class="hero-lede">
          Full-stack product engineer building AI-assisted products,
          Cloudflare/Convex platforms, Svelte/Astro apps, SwiftUI prototypes,
          and weird useful tools.
        </p>
        <p class="hero-support">
          I turn messy product and workflow ideas into shipped systems: UI,
          backend, agents, integrations, deployment, dashboards, and the
          operational details after the demo.
        </p>
        <div class="cta-row">
          <a class="btn primary" href="/store">Buy fixed-scope service</a>
          <a class="btn" href="/chat">Book paid discovery</a>
          <a class="btn" href="/products">View products</a>
          <a class="text-link" href="/resume">Download resume</a>
        </div>
      </div>
      <aside class="proof-panel" aria-label="Proof summary">
        <div class="panel-topline">
          <span>product-system.log</span>
          <span>2026</span>
        </div>
        <ol class="signal-list">
          <li><strong>Beyond frontend:</strong> Convex, Workers, D1, Docker, auth, dashboards, deploys.</li>
          <li><strong>After the demo:</strong> previews, rollback paths, backups, editor routes, notifications.</li>
          <li><strong>Buyer fit:</strong> fragile MVPs, AI workflows, publishing systems, platform rescue.</li>
        </ol>
        <div class="mini-metrics">
          {proofStats.map(([label, value]) => (
            <div>
              <span>{label}</span>
              <strong>{value}</strong>
            </div>
          ))}
        </div>
      </aside>
    </div>
  </section>

  <section class="section-band">
    <div class="container split-section">
      <div>
        <p class="eyebrow">What I build</p>
        <h2>Simple enough to reason about, strong enough to run.</h2>
      </div>
      <ul class="lane-list">
        {buildLanes.map((lane) => <li>{lane}</li>)}
      </ul>
    </div>
  </section>

  <section class="container section-block">
    <div class="section-heading">
      <p class="eyebrow">Service store</p>
      <h2>Fixed-scope packages with visible prices.</h2>
      <a class="text-link" href="/store">All packages</a>
    </div>
    <div class="store-grid compact">
      {featuredStoreProducts.map((product) => (
        <article class="store-card">
          <div class="card-kicker">
            <span>{product.category}</span>
            <span>{product.delivery}</span>
          </div>
          <h3><a href={`/store/${product.slug}`}>{product.title}</a></h3>
          <p>{product.summary}</p>
          <div class="price-line">
            <span>Listed price</span>
            <strong>{formatPrice(product)}</strong>
            <em>{formatLocalPrice(product)} local reference</em>
          </div>
          <div class="cta-row">
            <a class="btn primary" href={`/checkout/${product.slug}`}>Buy now</a>
            <a class="text-link" href={`/store/${product.slug}`}>Details</a>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="container section-block">
    <div class="section-heading">
      <p class="eyebrow">Services people search for</p>
      <h2>Clear entry points for product engineering work.</h2>
      <a class="text-link" href="/services">All services</a>
    </div>
    <div class="service-grid compact">
      {services.map((service) => (
        <article class="service-card">
          <p class="eyebrow">{service.shortTitle}</p>
          <h3><a href={`/services/${service.slug}`}>{service.title}</a></h3>
          <p>{service.summary}</p>
          <a class="product-action" href={`/services/${service.slug}`}>Read service page</a>
        </article>
      ))}
    </div>
  </section>

  <section class="section-band" id="proof">
    <div class="container">
    <div class="section-heading">
      <p class="eyebrow">Proof of work</p>
      <h2>Products and productized systems, not portfolio filler.</h2>
      <a class="text-link" href="/products">All products</a>
    </div>
    <div class="project-grid">
      {featuredProducts.map((project) => (
        <article class="project-card">
          <div class="card-kicker">
            <span>{project.status}</span>
            <span>{project.tags[0]}</span>
          </div>
          <h3>{project.title}</h3>
          <p class="outcome">{project.outcome}</p>
          <div class="diagram-strip" aria-label={`${project.title} architecture`}>
            {project.diagram.map((item) => <span>{item}</span>)}
          </div>
          <p><strong>Judgment shown:</strong> {project.judgment}</p>
          <a class="product-action" href={project.cta.href}>{project.cta.label}</a>
        </article>
      ))}
    </div>
    </div>
  </section>

  <section class="section-band work-band">
    <div class="container process-grid">
      <div>
        <p class="eyebrow">How I work</p>
        <h2>Paid discovery -> prototype -> build.</h2>
        <p>
          I do not do unpaid architecture or implementation plans. I am happy
          to do a short paid discovery/scope pass, then we can decide whether
          to continue into prototype or build.
        </p>
      </div>
      <ol class="process-list">
        <li>
          <span>01</span>
          <strong>Paid discovery</strong>
          <p>Map the product surface, risks, data model, integration points, and first shippable scope.</p>
        </li>
        <li>
          <span>02</span>
          <strong>Prototype or scoped rescue</strong>
          <p>Turn the riskiest workflow into something real enough to test, demo, or stabilize.</p>
        </li>
        <li>
          <span>03</span>
          <strong>Production build or retainer</strong>
          <p>Ship the system, wire the operations, and keep the boring pieces healthy.</p>
        </li>
      </ol>
    </div>
  </section>

  <section class="container section-block now-contact">
    <article>
      <p class="eyebrow">Now</p>
      <h2>Current activity</h2>
      <p>
        Working across Convex infrastructure, Cloudflare/GitHub control planes,
        Astro publishing systems, SwiftUI prototypes, and agent-assisted product
        workflows. I am especially interested in fragile MVPs that need to become
        real products.
      </p>
      <a class="text-link" href="/now">Read the lab notes</a>
    </article>
    <article class="contact-panel">
      <p class="eyebrow">Start here</p>
      <h2>Bring the messy version.</h2>
      <p>
        Send the product idea, the current state, the budget shape, and what
        needs to be true in the next two to six weeks.
      </p>
      <div class="cta-row">
        <a class="btn primary" href="/chat">Start a product scope</a>
        <a class="btn" href="mailto:malipetek@gmail.com?subject=Paid%20discovery%20for%20product%20engineering">Email directly</a>
      </div>
    </article>
  </section>
</BaseLayout>
