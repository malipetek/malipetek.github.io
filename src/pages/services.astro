---
import BaseLayout from "../layouts/BaseLayout.astro";
import { services } from "../data/services";
import { defaultStoreProductForService, formatDefaultServicePrice } from "../data/store";
import { absoluteUrl } from "../data/site";

const serviceOffer = (service: (typeof services)[number]) => {
  const product = defaultStoreProductForService(service.slug);
  if (!product) return undefined;

  return {
    "@type": "Offer",
    price: product.price,
    priceCurrency: product.currency,
    availability: "https://schema.org/InStock",
    url: absoluteUrl(`/store/${product.slug}`),
  };
};
const serviceListSchema = {
  "@type": "ItemList",
  "@id": `${absoluteUrl("/services")}#services`,
  name: "Product engineering services by Muhammet Ali Petek",
  itemListElement: services.map((service, index) => ({
    "@type": "ListItem",
    position: index + 1,
    item: {
      "@type": "Service",
      name: service.title,
      description: service.summary,
      url: absoluteUrl(`/services/${service.slug}`),
      offers: serviceOffer(service),
    },
  })),
};
---

<BaseLayout
  title="Services"
  description="Product engineering services for AI workflows, agentic commerce readiness, Cloudflare/Convex platforms, Svelte/Astro systems, SwiftUI prototypes, Shopify app integrations, and technical rescue."
  wide={true}
  schema={[serviceListSchema]}
>
  <section class="page-hero full-bleed">
    <div class="container">
      <p class="eyebrow">Services / search surface</p>
      <h1>Find the service by the problem you are trying to solve.</h1>
      <p>
        These pages are written for humans first and search engines second:
        clear answer blocks, visible proof, direct fit, and purchasable
        fixed-scope packages when the work has a clean boundary.
      </p>
      <div class="cta-row">
        <a class="btn primary" href="/store">Buy fixed-scope package</a>
        <a class="btn" href="/contact">Contact</a>
      </div>
    </div>
  </section>

  <section class="container section-block">
    <div class="service-grid">
      {services.map((service) => (
        <article class="service-card">
          <p class="eyebrow">{service.shortTitle}</p>
          <h2><a href={`/services/${service.slug}`}>{service.title}</a></h2>
          <p>{service.summary}</p>
          <div class="price-line service-price">
            <span>Default package amount</span>
            <strong>{formatDefaultServicePrice(service.slug)}</strong>
          </div>
          <ul class="plain-list">
            {service.keywords.slice(0, 3).map((keyword) => <li>{keyword}</li>)}
          </ul>
          <div class="cta-row">
            <a class="product-action" href={`/services/${service.slug}`}>Read service page</a>
            <a class="text-link" href="/store">Buy package</a>
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
