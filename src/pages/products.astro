---
import BaseLayout from "../layouts/BaseLayout.astro";
import { products } from "../data/projects";
import { absoluteUrl } from "../data/site";

const itemList = {
  "@type": "ItemList",
  "@id": `${absoluteUrl("/products")}#products`,
  name: "Muhammet Ali Petek products and productized systems",
  itemListElement: products.map((product, index) => ({
    "@type": "ListItem",
    position: index + 1,
    url: absoluteUrl(`/products/${product.slug}`),
    name: product.title,
  })),
};
---

<BaseLayout
  title="Products"
  description="Products and productized systems by Muhammet Ali Petek: GPTflare, Convexer, Shopify workflow app, AI publishing platforms, SwiftUI/Convex prototypes, and technical rescue tools."
  wide={true}
  schema={[itemList]}
>
  <section class="page-hero full-bleed">
    <div class="container">
      <p class="eyebrow">Products / proof</p>
      <h1>Products, platforms, and installable directions.</h1>
      <p>
        Some are live, some are prototypes, and some are productized services on
        the way to installable apps. The common thread is the same: real UI,
        backend, deployment, workflow design, and operational judgment.
      </p>
    </div>
  </section>

  <section class="container section-block">
    <div class="product-hub-grid">
      {products.map((product) => (
        <article class="product-card" id={product.slug}>
          <div class="product-card-main">
            <div class="card-kicker">
              <span>{product.status}</span>
              <span>{product.tags.join(" / ")}</span>
            </div>
            <h2><a href={`/products/${product.slug}`}>{product.title}</a></h2>
            <p class="outcome">{product.outcome}</p>
            <p>{product.problem}</p>
            <div class="diagram-strip" aria-label={`${product.title} workflow`}>
              {product.diagram.map((item) => <span>{item}</span>)}
            </div>
          </div>
          <aside class="product-cta-panel">
            <a class="btn primary" href={product.cta.href}>{product.cta.label}</a>
            <a class="text-link" href={`/products/${product.slug}`}>Read product note</a>
            <p>{product.cta.note}</p>
          </aside>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
