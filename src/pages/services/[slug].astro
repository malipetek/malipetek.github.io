---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { services } from "../../data/services";
import { products } from "../../data/projects";
import { absoluteUrl, site } from "../../data/site";

export function getStaticPaths() {
  return services.map((service) => ({
    params: { slug: service.slug },
    props: { service },
  }));
}

const { service } = Astro.props;
const relatedProducts = products.filter((product) =>
  service.relatedProducts.includes(product.slug)
);
const breadcrumbs = [
  { name: "Home", href: "/" },
  { name: "Services", href: "/services" },
  { name: service.title, href: `/services/${service.slug}` },
];
const breadcrumbSchema = {
  "@type": "BreadcrumbList",
  "@id": `${absoluteUrl(`/services/${service.slug}`)}#breadcrumbs`,
  itemListElement: breadcrumbs.map((item, index) => ({
    "@type": "ListItem",
    position: index + 1,
    name: item.name,
    item: absoluteUrl(item.href),
  })),
};
const serviceSchema = {
  "@type": "Service",
  "@id": `${absoluteUrl(`/services/${service.slug}`)}#service`,
  name: service.title,
  description: service.summary,
  provider: { "@id": `${site.url}/#person` },
  areaServed: "Worldwide",
  serviceType: service.keywords.join(", "),
  url: absoluteUrl(`/services/${service.slug}`),
};
const faqSchema = {
  "@type": "FAQPage",
  "@id": `${absoluteUrl(`/services/${service.slug}`)}#faq`,
  mainEntity: service.faq.map((item) => ({
    "@type": "Question",
    name: item.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.answer,
    },
  })),
};
---

<BaseLayout
  title={service.title}
  description={service.summary}
  wide={true}
  schema={[breadcrumbSchema, serviceSchema, faqSchema]}
>
  <section class="page-hero full-bleed">
    <div class="container narrow-copy">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        {breadcrumbs.map((item, index) => (
          <>
            {index > 0 && <span>/</span>}
            {index < breadcrumbs.length - 1 ? (
              <a href={item.href}>{item.name}</a>
            ) : (
              <strong>{item.name}</strong>
            )}
          </>
        ))}
      </nav>
      <p class="eyebrow">Service</p>
      <h1>{service.title}</h1>
      <p>{service.summary}</p>
      <div class="cta-row">
        <a class="btn primary" href="/store">Buy fixed-scope package</a>
        <a class="btn" href={`/chat?intent=${service.slug}`}>Email scope</a>
        <a class="btn" href="/products">See related products</a>
      </div>
    </div>
  </section>

  <section class="container section-block split-section">
    <div>
      <p class="eyebrow">Direct answer</p>
      <h2>What this service means.</h2>
    </div>
    <p class="large-note">{service.answer}</p>
  </section>

  <section class="section-band">
    <div class="container service-proof-grid">
      <article>
        <p class="eyebrow">Best for</p>
        <ul class="lane-list single-column">
          {service.bestFor.map((item) => <li>{item}</li>)}
        </ul>
      </article>
      <article>
        <p class="eyebrow">Deliverables</p>
        <ul class="lane-list single-column">
          {service.deliverables.map((item) => <li>{item}</li>)}
        </ul>
      </article>
    </div>
  </section>

  <section class="container section-block">
    <div class="section-heading">
      <p class="eyebrow">Proof and products</p>
      <h2>Related product evidence.</h2>
      <a class="text-link" href="/products">All products</a>
    </div>
    <div class="project-grid">
      {relatedProducts.map((product) => (
        <article class="project-card">
          <div class="card-kicker">
            <span>{product.status}</span>
            <span>{product.tags[0]}</span>
          </div>
          <h3><a href={`/products/${product.slug}`}>{product.title}</a></h3>
          <p class="outcome">{product.outcome}</p>
          <a class="product-action" href={product.cta.href}>{product.cta.label}</a>
        </article>
      ))}
    </div>
  </section>

  <section class="section-band">
    <div class="container faq-section">
      <div>
        <p class="eyebrow">FAQ</p>
        <h2>Search-friendly answers.</h2>
      </div>
      <div class="faq-list">
        {service.faq.map((item) => (
          <article>
            <h3>{item.question}</h3>
            <p>{item.answer}</p>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
